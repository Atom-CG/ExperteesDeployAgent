{
  "name": "expertees-deploy",
  "displayName": "ExperteesDeploy",
  "description": "Agent ALM Power Platform et Code Apps — packagez et déployez vos Code Apps et solutions Dataverse sans quitter VS Code.",
  "version": "1.0.8",
  "publisher": "Atom-CG",
  "author": {
    "name": "Atom-CG"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atom-CG/ExperteesDeployAgent.git"
  },
  "bugs": {
    "url": "https://github.com/Atom-CG/ExperteesDeployAgent/issues"
  },
  "homepage": "https://github.com/Atom-CG/ExperteesDeployAgent#readme",
  "engines": {
    "vscode": "^1.124.0"
  },
  "categories": [
    "Chat",
    "Other"
  ],
  "keywords": [
    "power platform",
    "power apps",
    "dataverse",
    "alm",
    "code apps",
    "copilot chat"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "expertees-deploy.agent",
        "name": "Expertees-Deploy",
        "fullName": "ExperteesDeploy - ALM Power Platform",
        "description": "Guide pas-à-pas pour packager et déployer vos Code Apps sur la Power Platform.",
        "isSticky": true
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package-vsix": "vsce package --out expertees-deploy.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.124.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@vscode/vsce": "^3.2.1",
    "typescript-eslint": "^8.61.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "ts-loader": "^9.6.2",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
